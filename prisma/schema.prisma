// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  phone     String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
  projectRequests ProjectRequest[]
  
  @@map("customers")
}

model ProjectRequest {
  id          String     @id @default(cuid())
  customerId  String
  customer    Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  category    String     // "carpentry", "handyman", "fence", etc.
  location    String
  timeline    String     // "ASAP", "2 weeks", etc.
  description String     @db.Text

  status      String     @default("submitted") // submitted, analyzing, approved, sent, accepted, declined
  approvalStatus String @default("awaiting_analysis") // awaiting_analysis, awaiting_client_approval, active, denied

  clientApprovedAt DateTime?
  clientDeniedAt   DateTime?
  emailSentAt      DateTime?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  uploadedAssets UploadedAsset[]
  estimate       Estimate?

  @@map("project_requests")
}

model UploadedAsset {
  id         String     @id @default(cuid())
  projectId  String
  project    ProjectRequest @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  filename   String
  s3Url      String
  mimeType   String
  fileSize   Int
  
  createdAt  DateTime   @default(now())
  
  @@map("uploaded_assets")
}

model Estimate {
  id          String     @id @default(cuid())
  projectId   String     @unique
  project     ProjectRequest @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Estimates
  lowEstimate Float
  expectedEstimate Float
  highEstimate Float

  // Breakdown & analysis
  breakdown   String     @db.Text
  rawAnalysis String?    @db.Text
  confidence  Float      @default(0.5)

  // Additional details
  materialRequirements String? @db.Text
  timeEstimation      String? // e.g., "3-5 days", "1-2 weeks"
  isEdited           Boolean @default(false) // tracks if admin manually adjusted

  // Status
  status      String     @default("pending")
  sentAt      DateTime?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("estimates")
}

model EstimateHistory {
  id          String     @id @default(cuid())
  
  // Copy of estimate at time of creation
  estimateJson Json
  
  // Actual outcome
  accepted    Boolean?
  actualCost  Float?
  completedAt DateTime?
  notes       String?    @db.Text
  
  createdAt   DateTime   @default(now())
  
  @@map("estimate_history")
}

model AdminUser {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String     // bcrypt hash
  name      String

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("admin_users")
}

model ThemeSettings {
  id        String     @id @default(cuid())

  // Colors
  primaryColor     String   @default("#b45309") // Amber-700
  secondaryColor   String   @default("#78350f") // Amber-900
  accentColor      String   @default("#ea580c") // Orange
  textPrimary      String   @default("#1f2937") // Gray-900
  textSecondary    String   @default("#6b7280") // Gray-500
  backgroundColor  String   @default("#f9fafb") // Gray-50
  borderColor      String   @default("#e5e7eb") // Gray-200

  // Typography
  fontFamily       String   @default("system-ui, -apple-system, sans-serif")
  headingFont      String   @default("system-ui, -apple-system, sans-serif")

  // Branding
  siteName         String   @default("Hearth & Hollow")
  siteDescription  String   @default("Custom handyman and carpentry services")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("theme_settings")
}

