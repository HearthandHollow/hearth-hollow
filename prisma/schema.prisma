// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  phone     String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
  projectRequests ProjectRequest[]
  
  @@map("customers")
}

model ProjectRequest {
  id          String     @id @default(cuid())
  customerId  String
  customer    Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  category    String     // "carpentry", "handyman", "fence", etc.
  location    String
  timeline    String     // "ASAP", "2 weeks", etc.
  description String     @db.Text

  status      String     @default("submitted") // submitted, analyzing, approved, sent, accepted, declined
  approvalStatus String @default("awaiting_analysis") // awaiting_analysis, awaiting_client_approval, active, denied

  clientApprovedAt DateTime?
  clientDeniedAt   DateTime?
  emailSentAt      DateTime?

  // Scheduling (client picks a date after approving)
  scheduledDate DateTime?  // the booked day (date only; time of day in scheduledSlot)
  scheduledSlot String?    // "morning" | "afternoon" preference
  scheduledAt   DateTime?  // when the client made the booking

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  uploadedAssets UploadedAsset[]
  estimate       Estimate?
  invoices       Invoice[]

  @@map("project_requests")
}

model AvailabilitySettings {
  id String @id @default(cuid())

  // Which weekdays are bookable
  sunday    Boolean @default(false)
  monday    Boolean @default(false)
  tuesday   Boolean @default(false)
  wednesday Boolean @default(false)
  thursday  Boolean @default(true)
  friday    Boolean @default(true)
  saturday  Boolean @default(true)

  // How far ahead clients can book
  bookingWindowWeeks Int @default(8)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("availability_settings")
}

model BlockedDate {
  id        String   @id @default(cuid())
  date      DateTime @unique // a specific closed-off day (stored at noon UTC)
  createdAt DateTime @default(now())

  @@map("blocked_dates")
}

model OpenDate {
  id        String   @id @default(cuid())
  date      DateTime @unique // a one-off opened day (overrides a normally-off weekday)
  createdAt DateTime @default(now())

  @@map("open_dates")
}

model GalleryImage {
  id        String   @id @default(cuid())
  s3Key     String
  caption   String?
  createdAt DateTime @default(now())

  @@map("gallery_images")
}

model UploadedAsset {
  id         String     @id @default(cuid())
  projectId  String
  project    ProjectRequest @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  filename   String
  s3Url      String
  mimeType   String
  fileSize   Int
  
  createdAt  DateTime   @default(now())
  
  @@map("uploaded_assets")
}

model Estimate {
  id          String     @id @default(cuid())
  projectId   String     @unique
  project     ProjectRequest @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Estimates
  lowEstimate Float
  expectedEstimate Float
  highEstimate Float

  // Breakdown & analysis
  breakdown   String     @db.Text
  rawAnalysis String?    @db.Text
  confidence  Float      @default(0.5)

  // Additional details
  materialRequirements String? @db.Text
  materialList        Json?   // [{ item, quantity, unit, estimatedPrice }] structured material list w/ pricing
  timeEstimation      String? // e.g., "3-5 days", "1-2 weeks"
  isEdited           Boolean @default(false) // tracks if admin manually adjusted

  // Which tier (low/expected/high) the admin has selected to actually quote the customer
  selectedTier String @default("expected") // "low" | "expected" | "high"

  // Status
  status      String     @default("pending")
  sentAt      DateTime?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("estimates")
}

model EstimateHistory {
  id          String     @id @default(cuid())
  
  // Copy of estimate at time of creation
  estimateJson Json
  
  // Actual outcome
  accepted    Boolean?
  actualCost  Float?
  completedAt DateTime?
  notes       String?    @db.Text
  
  createdAt   DateTime   @default(now())
  
  @@map("estimate_history")
}

model Invoice {
  id          String     @id @default(cuid())
  projectId   String
  project     ProjectRequest @relation(fields: [projectId], references: [id], onDelete: Cascade)

  invoiceNumber String   @unique

  // [{ description, quantity, unitPrice, total }]
  lineItems   Json

  subtotal    Float
  total       Float
  notes       String?    @db.Text

  status      String     @default("draft") // draft, sent, paid
  sentAt      DateTime?

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("invoices")
}

model AdminUser {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String     // bcrypt hash
  name      String

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("admin_users")
}

model ThemeSettings {
  id        String     @id @default(cuid())

  // Colors
  primaryColor     String   @default("#b45309") // Amber-700
  secondaryColor   String   @default("#78350f") // Amber-900
  accentColor      String   @default("#ea580c") // Orange
  textPrimary      String   @default("#1f2937") // Gray-900
  textSecondary    String   @default("#6b7280") // Gray-500
  backgroundColor  String   @default("#f9fafb") // Gray-50
  borderColor      String   @default("#e5e7eb") // Gray-200

  // Typography
  fontFamily       String   @default("system-ui, -apple-system, sans-serif")
  headingFont      String   @default("system-ui, -apple-system, sans-serif")

  // Branding
  siteName         String   @default("Hearth & Hollow")
  siteDescription  String   @default("Custom handyman and carpentry services")

  // Homepage imagery — editable from the admin Theme page. Defaults point at
  // royalty-free Unsplash stock photos; swap in real photos any time without
  // a code change.
  heroImageUrl      String   @default("https://images.unsplash.com/photo-1757605327126-9baefea3348b?auto=format&fit=crop&w=1600&q=80")
  craftImageUrl     String   @default("https://images.unsplash.com/photo-1631396326646-c06a935ff3a6?auto=format&fit=crop&w=1200&q=80")
  gatheringImageUrl String   @default("https://images.unsplash.com/photo-1746701905946-f1babf656914?auto=format&fit=crop&w=1200&q=80")
  homesteadImageUrl String   @default("https://images.unsplash.com/photo-1771425890623-f17451025495?auto=format&fit=crop&w=1200&q=80")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("theme_settings")
}

