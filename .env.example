# Database
DATABASE_URL="postgresql://user:password@host:5432/hearth_hollow_quotes"

# NextAuth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://thehearthhollow.com"

# AWS S3 (or use Vercel Blob)
AWS_ACCESS_KEY_ID="your-key"
AWS_SECRET_ACCESS_KEY="your-secret"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="hearth-hollow-quotes"

# Claude API
ANTHROPIC_API_KEY="your-key"

# Email (Resend)
RESEND_API_KEY="your-key"
ADMIN_EMAIL="your-email@thehearthhollow.com"
ADMIN_NAME="Your Name"

# Public URLs
NEXT_PUBLIC_SITE_URL="https://thehearthhollow.com"
NEXT_PUBLIC_COMPANY_NAME="The Hearth & Hollow"

# Push notifications (OneSignal) — admin PWA
# App ID + REST API Key come from the OneSignal dashboard (Web app > Settings > Keys & IDs).
ONESIGNAL_APP_ID="your-onesignal-app-id"
NEXT_PUBLIC_ONESIGNAL_APP_ID="your-onesignal-app-id"
ONESIGNAL_REST_API_KEY="your-onesignal-rest-api-key"

# Shared secret for the external cron hitting /api/cron/check-email-replies
CRON_SECRET="generate-a-long-random-string"
